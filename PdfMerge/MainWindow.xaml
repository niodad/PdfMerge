<Window x:Class="PdfMerge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PdfMerge"
        mc:Ignorable="d"
        Title="PDF Merger" Height="500" Width="700"
        Background="#F0F0F0"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="PDF Merger" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   Foreground="#333333"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>
        
        <!-- Control Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Button Content="Add Files" 
                    Click="Button_Click" 
                    Margin="5" 
                    Padding="15,8"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"/>
            <Button Content="Delete Selected" 
                    Click="Button_Delete_Click" 
                    Margin="5" 
                    Padding="15,8"
                    Background="#F44336"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"/>
            <Button Content="Clear All" 
                    Click="Button_Clear_Click" 
                    Margin="5" 
                    Padding="15,8"
                    Background="#9C27B0"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"/>
            <Button Content="Move Up" 
                    Click="Up_click" 
                    Margin="5" 
                    Padding="15,8"
                    Background="#2196F3"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"/>
            <Button Content="Move Down" 
                    Click="Down_click" 
                    Margin="5" 
                    Padding="15,8"
                    Background="#2196F3"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"/>
        </StackPanel>
        
        <!-- File List -->
        <Border Grid.Row="2" 
                Background="White" 
                BorderBrush="#CCCCCC" 
                BorderThickness="1"
                CornerRadius="5"
                Margin="0,0,0,20">
            <ListBox Name="FileListBox" 
                     ItemsSource="{Binding FileList}" 
                     Drop="ImagePanel_Drop" 
                     AllowDrop="true" 
                     SelectionMode="Multiple"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <TextBlock Text="📄" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding}" 
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       FontSize="14"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
        
        <!-- Output Section -->
        <Border Grid.Row="3" 
                Background="White" 
                BorderBrush="#CCCCCC" 
                BorderThickness="1"
                CornerRadius="5"
                Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Output filename:" 
                           VerticalAlignment="Center" 
                           Margin="0,0,10,0"
                           FontSize="14"
                           FontWeight="SemiBold"/>
                <TextBox Name="filename" 
                         Text="merged_document" 
                         Width="200" 
                         Margin="0,0,15,0"
                         Padding="8,5"
                         FontSize="14"
                         BorderBrush="#CCCCCC"
                         BorderThickness="1"/>
                <Button Content="Merge PDFs" 
                        Click="Button_Merge_Click" 
                        Padding="20,8"
                        Background="#FF9800"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        FontSize="14"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
